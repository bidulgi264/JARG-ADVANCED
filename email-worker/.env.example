PORT=3000
ADMIN_TOKEN=replace-this

HINT_FROM=JARG Hint Bot <your-account@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-google-app-password

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-account@gmail.com
IMAP_PASS=your-google-app-password
IMAP_MAILBOX=INBOX
IMAP_POLL_MS=30000

JARG_API_URL=http://localhost:3100
JARG_EMAIL_SECRET=use-the-same-value-as-JARG_ADVANCED-EMAIL_WEBHOOK_SECRET
